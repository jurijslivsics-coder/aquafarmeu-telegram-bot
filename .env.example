TELEGRAM_BOT_TOKEN=put_your_telegram_token_here
OPENAI_API_KEY=put_your_openai_api_key_here

# Optional, but recommended after testing.
# Comma-separated Telegram numeric user IDs, for example: 12345,67890
ALLOWED_TELEGRAM_USER_IDS=

# Render will provide PORT automatically.
# Set WEBHOOK_URL on Render after the service is created, for example:
# https://aquafarmeu-bot.onrender.com
WEBHOOK_URL=

# You can change these later.
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
